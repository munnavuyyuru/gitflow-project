#!/bin/bash

commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Check commit message format:
# feat: add feature, fix: bug fix, docs: update readme

pattern="^(feat|fix|docs|style|refactor|test|chore|ci|perf|build|revert)(\(.+\))?: .{10,}"

if ! echo "$commit_msg" | grep -Eq "$pattern"; then
    echo "Invalid commit message format! ✖"
    echo ""
    echo "Format: <type>(scope): <message>"
    echo ""
    echo "Types: feat, fix, docs, style, refactor, test, chore, ci, perf, build, revert"
    echo ""
    echo "Example: feat: add user authentication"
    echo "Example: fix(api): resolve timeout issue"
    exit 1
fi

echo "Commit message format valid ✔"
exit 0

